{
  "cleanupPeriodDays": 720,
  "env": {
    "CLAUDE_BASH_TIMEOUT_MS": "600000",
    "CLAUDE_MAX_BASH_TIMEOUT_MS": "86400000",
    "CLAUDE_MAX_OUTPUT_TOKENS": "42069",
    "CLAUDE_CODE_MAX_THINKING_TOKENS": "32000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MCP_TOOL_TIMEOUT": "3600000"
  },
  "teammateMode": "tmux",
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(tree *)",
      "Bash(eza *)",
      "Bash(bun *)",
      "Bash(uv *)",
      "Bash(fd *)",
      "Bash(rg *)",
      "Bash(tmux *)",
      "Bash(npm run *)",
      "Bash(which *)",
      "Bash(* --version)",
      "Bash(* --help)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git filter-repo *)",
      "Bash(rm -rf ~/box*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opusplan",
  "effortLevel": "high",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/workflow-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/auto-memory.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/session-baseline.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[POST-COMPACTION] context was compacted. check TodoWrite for GOAL/NOTEs. check auto memory for session context.' && (git log --oneline -3 2>/dev/null && git diff --stat HEAD 2>/dev/null || true)",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"needs your attention\" with title \"Claude Code\"' 2>/dev/null; (command -v notify-send >/dev/null && notify-send 'Claude Code' 'needs your attention') 2>/dev/null; exit 0"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/teammate-idle.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "a teammate marked a task completed. evaluate if completion is justified.\n\ntask info: $ARGUMENTS\n\ncheck:\n1. does task_subject describe work that could plausibly be done?\n2. if task_description exists, are there specific deliverables mentioned?\n3. any indication the task was only partially completed?\n\nrespond {\"ok\": true} if legitimate, or {\"ok\": false, \"reason\": \"specific concern\"} if clear red flag. err on the side of allowing — only block on obvious incompleteness.",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/normalize-commands.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/codex-nudge.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/tokf-hook.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/bash-timeout.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/track-edit-repo.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/auto-format.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/git-snapshot.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/box/tools/hooks/precompact-context.sh",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {},
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "promptCaching": true,
  "skipDangerousModePermissionPrompt": true
}
